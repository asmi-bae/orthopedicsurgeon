{
  "name": "orthopedic-platform",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --ui=tui",
    "dev:api": "turbo dev --filter=api",
    "dev:admin": "turbo dev --filter=admin",
    "dev:doctor": "turbo dev --filter=doctor",
    "dev:public": "turbo dev --filter=web",
    "lint": "turbo lint",
    "test": "turbo test"
  },
  "devDependencies": {
    "turbo": "latest"
  },
  "packageManager": "pnpm@10.31.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "less",
      "lmdb",
      "msgpackr-extract",
      "nx"
    ],
    "overrides": {
      "@angular/animations": "21.2.1",
      "@angular/cdk": "21.2.1",
      "@angular/common": "21.2.1",
      "@angular/compiler": "21.2.1",
      "@angular/compiler-cli": "21.2.1",
      "@angular/core": "21.2.1",
      "@angular/forms": "21.2.1",
      "@angular/material": "21.2.1",
      "@angular/platform-browser": "21.2.1",
      "@angular/platform-browser-dynamic": "21.2.1",
      "@angular/platform-server": "21.2.1",
      "@angular/router": "21.2.1",
      "@angular-devkit/build-angular": "21.2.1",
      "@angular-devkit/core": "21.2.1",
      "@angular-devkit/schematics": "21.2.1",
      "@angular/build": "21.2.1",
      "@angular/cli": "21.2.1"
    }
  }
}