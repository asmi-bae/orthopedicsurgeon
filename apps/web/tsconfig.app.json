{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/app",
    "types": []
  },
  "files": [
    "src/main.ts",
    "src/app/app.config.ts",
    "src/app/app.component.ts"
  ],
  "include": [
    "src/**/*.ts",
    "../../packages/*/src/**/*.ts"
  ],
  "exclude": [
    "src/**/*.spec.ts",
    "../../packages/*/src/**/*.spec.ts",
    "../../packages/*/src/**/__tests__/**/*.ts"
  ]
}