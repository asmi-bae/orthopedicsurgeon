{
    "info": {
        "_postman_id": "doctor-api-collection",
        "name": "Orthopedic Surgeon - Doctor API",
        "description": "API collection for Doctor role in the Orthopedic Surgeon Platform. Base URL: http://localhost:8080/api/v1",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "🔐 Auth",
            "item": [
                {
                    "name": "Login (Doctor)",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "var json = pm.response.json();",
                                    "if (json.sessionToken) {",
                                    "  pm.collectionVariables.set('session_token', json.sessionToken);",
                                    "}"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{access_token}}",
                                "type": "text"
                            }
                        ],
                        "url": "{{base_url}}/doctor/auth/login",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"doctor@orthopedicsurgeon.com\",\n  \"password\": \"doctor@orthopedicsurgeon.com\"\n}"
                        }
                    }
                },
                {
                    "name": "Refresh Token",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{access_token}}",
                                "type": "text"
                            }
                        ],
                        "url": "{{base_url}}/doctor/auth/refresh",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}"
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "var json = pm.response.json();",
                                    "if (json.accessToken) {",
                                    "  pm.collectionVariables.set('access_token', json.accessToken);",
                                    "  pm.collectionVariables.set('refresh_token', json.refreshToken);",
                                    "}"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Verify MFA (Doctor)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{access_token}}",
                                "type": "text"
                            }
                        ],
                        "url": "{{base_url}}/doctor/auth/login/mfa",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"sessionToken\": \"{{session_token}}\",\n  \"code\": \"123456\"\n}"
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "var json = pm.response.json();",
                                    "if (json.accessToken) {",
                                    "  pm.collectionVariables.set('access_token', json.accessToken);",
                                    "  pm.collectionVariables.set('refresh_token', json.refreshToken);",
                                    "}"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Get Current User",
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/doctor/auth/me",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{access_token}}",
                                "type": "text"
                            }
