{
  "role": "VISITOR",
  "base_url": "/api/v1/public",
  "endpoints": [
    {
      "path": "/auth/login",
      "method": "POST",
      "description": "Public Login"
    },
    {
      "path": "/auth/register/patient",
      "method": "POST",
      "description": "Patient Registration"
    },
    {
      "path": "/blog",
      "method": "GET",
      "description": "Read Public Blog Posts"
    },
    {
      "path": "/doctors",
      "method": "GET",
      "description": "Search/View Doctor Profiles"
    },
    {
      "path": "/health/ping",
      "method": "GET",
      "description": "System Health Check"
    }
  ]
}
