  "item": [
    {
      "name": "🔐 GROUP A: PUBLIC AUTH (no token required)",
      "item": [
        {
          "name": "POST /auth/login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.accessToken) {",
                  "    pm.collectionVariables.set(\"access_token\", jsonData.data.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/patient/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "patient",
                "auth",
                "login"
              ]
            },
            "description": "ID: A-01\nBody: { email, password }",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{patient_email}}\",\n  \"password\": \"{{default_password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "POST /auth/register/patient",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/patient/auth/register/patient",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "patient",
                "auth",
                "register",
                "patient"
              ]
            },
            "description": "ID: A-02",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Shoaib\",\n  \"lastName\": \"Hasan\",\n  \"email\": \"shoaib123@example.com\",\n  \"password\": \"shoaib123\",\n  \"confirmPassword\": \"shoaib123\",\n  \"phone\": \"+8801700000000\",\n  \"dateOfBirth\": \"1990-01-01\",\n  \"gender\": \"MALE\",\n  \"role\": \"PATIENT\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "POST /auth/google",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/patient/auth/google",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "patient",
                "auth",
                "google"
              ]
            },
            "description": "ID: A-03",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idToken\": \"{{google_id_token}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        }
      ]
