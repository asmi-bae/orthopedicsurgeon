{
  "role": "PATIENT",
  "base_url": "/api/v1/patient",
  "endpoints": [
    {
      "path": "/portal/dashboard",
      "method": "GET",
      "description": "Patient Personal Dashboard"
    },
    {
      "path": "/portal/profile",
      "method": "GET",
      "description": "View/Update Own Profile"
    },
    {
      "path": "/portal/appointments/upcoming",
      "method": "GET",
      "description": "View Upcoming Appointments"
    },
    {
      "path": "/portal/health/vitals/latest",
      "method": "GET",
      "description": "View Personal Health Records"
    },
    {
      "path": "/media/upload",
      "method": "POST",
      "description": "Upload Personal Profile Image/Document"
    },
    {
      "path": "/media/delete",
      "method": "DELETE",
      "description": "Delete Personal Media"
    }
  ]
}
