{
  "role": "DOCTOR_ADMIN",
  "base_url": "/api/v1/doctor",
  "endpoints": [
    {
      "path": "/dashboard",
      "method": "GET",
      "description": "Doctor Clinical Dashboard"
    },
    {
      "path": "/appointments",
      "method": "GET",
      "description": "Manage Assigned Appointments"
    },
    {
      "path": "/patients",
      "method": "GET",
      "description": "Manage Patient Records"
    },
    {
      "path": "/prescriptions",
      "method": "POST",
      "description": "Issue New Prescription"
    },
    {
      "path": "/lab-reports",
      "method": "POST",
      "description": "Create Lab Report Request"
    },
    {
      "path": "/website/hero-slides",
      "method": "GET",
      "description": "Manage Hero Slides"
    },
    {
      "path": "/blog/posts",
      "method": "POST",
      "description": "Create Blog Post"
    },
    {
      "path": "/payments",
      "method": "GET",
      "description": "Track Revenue"
    },
    {
      "path": "/reviews",
      "method": "POST",
      "description": "Moderate Patient Reviews"
    }
  ]
}
